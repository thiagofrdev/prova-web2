<!DOCTYPE html>
<html lang="pt-BR">

<head>
    <meta charset="UTF-8">
    <title>Lista de Vacinas</title>
</head>

<body>
    <h2>Vacinas Cadastradas no Sistema</h2>
    <a href="/cadastro-vacina.html">Cadastrar Nova Vacina</a>
    <hr>

    <table border="1" cellpadding="5">
        <thead>
            <tr>
                <th>ID</th>
                <th>Nome da Criança</th>
                <th>Vacina Aplicada</th>
                <th>Tipo de Dose</th>
            </tr>
        </thead>
        <tbody>
            <% aplicacoes.forEach(ap=> { %>
                <tr>
                    <td>
                        <%= ap.id %>
                    </td>
                    <td>
                        <%= ap.crianca.nomeCompleto %>
                    </td>
                    <td>
                        <%= ap.vacina.nome %>
                    </td>
                    <td>
                        <%= ap.tipoDose %>
                    </td>
                </tr>
                <% }) %>
        </tbody>
    </table>
</body>

</html>